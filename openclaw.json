{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace-socrates",
      "thinkingDefault": "medium",
      "timeoutSeconds": 300,
      "subagents": {
        "allowAgents": ["*"]
      }
    },
    "list": [
      {
        "id": "socrates",
        "name": "Socrates",
        "default": true,
        "model": "openai/gpt-5.5",
        "thinkingDefault": "low",
        "workspace": "~/.openclaw/workspace-socrates",
        "identity": {
          "avatar": "avatar.png"
        },
        "tools": {
          "allow": [
            "sessions_send",
            "sessions_spawn",
            "sessions_yield",
            "sessions_history",
            "sessions_list",
            "read"
          ]
        }
      },
      {
        "id": "plato",
        "name": "Plato",
        "model": "openai/gpt-5.5",
        "thinkingDefault": "medium",
        "workspace": "~/.openclaw/workspace-plato",
        "identity": {
          "avatar": "avatar.png"
        },
        "tools": {
          "allow": [
            "sessions_send",
            "sessions_history",
            "read"
          ],
          "deny": [
            "browser",
            "canvas"
          ]
        }
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "plugins": {
    "entries": {
      "openai": { "enabled": true },
      "google": { "enabled": true }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "<YOUR_TOKEN_HERE>"
    }
  }
}
